# Salin blok ini ke .env / .env.example proyek.
# (Ditaruh file terpisah karena akses .env* diblok permission tool.)

# --- Spekta LLM (SpecEngine) ---
# Driver: anthropic | openai | stub (auto: anthropic bila ANTHROPIC_API_KEY terisi,
# openai bila OPENAI_API_KEY terisi, selain itu stub deterministik tanpa biaya token).
# SPEKTA_LLM_DRIVER=anthropic

# Anthropic / Anthropic-compatible (z.ai, Kimi, proxy)
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI-compatible (OpenAI, Groq, DeepSeek, OpenRouter, Ollama)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
#   Groq:   https://api.groq.com/openai/v1
#   Ollama: http://localhost:11434/v1  (OPENAI_API_KEY=ollama)

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
GOOGLE_LINK_REDIRECT_URI="${APP_URL}/settings/profile/google/callback"

# Model routing per kelas node (BR-50) — sesuaikan dengan provider.
# reasoning: PRD, REQUIREMENTS, ARCHITECTURE + wizard understanding/structure
# economy:   PROJECT_BRIEF, WIREFRAMES, DESIGN, ROADMAP, TASK_BREAKDOWN
# standard:  sisanya
# SPEKTA_MODEL_REASONING=claude-fable-5
# SPEKTA_MODEL_STANDARD=claude-sonnet-5
# SPEKTA_MODEL_ECONOMY=claude-haiku-4-5-20251001
#
# Via proxy sendiri (9router/omnirouter): set driver openai + base_url proxy,
# pakai alias by-role — mapping ke model real diatur di sisi proxy.
# SPEKTA_LLM_DRIVER=openai
# OPENAI_BASE_URL=https://proxy-kamu/v1
# SPEKTA_MODEL_REASONING=spekta-reasoning
# SPEKTA_MODEL_STANDARD=spekta-standard
# SPEKTA_MODEL_ECONOMY=spekta-economy

# --- Midtrans (FR-23) ---
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
# MIDTRANS_IS_PRODUCTION=false
