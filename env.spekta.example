# Salin blok ini ke .env / .env.example proyek.
# (Ditaruh file terpisah karena akses .env* diblok permission tool.)

# --- Spekta LLM (SpecEngine) ---
# Driver: anthropic | openai | stub (auto: anthropic bila ANTHROPIC_API_KEY terisi,
# openai bila OPENAI_API_KEY terisi, selain itu stub deterministik tanpa biaya token).
# SPEKTA_LLM_DRIVER=anthropic

# Anthropic / Anthropic-compatible (z.ai, Kimi, proxy)
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI-compatible (OpenAI, Groq, DeepSeek, OpenRouter, Ollama)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
#   Groq:   https://api.groq.com/openai/v1
#   Ollama: http://localhost:11434/v1  (OPENAI_API_KEY=ollama)

# Model routing per kelas node (BR-50) — sesuaikan dengan provider
# SPEKTA_MODEL_REASONING=claude-fable-5
# SPEKTA_MODEL_STANDARD=claude-sonnet-5
# SPEKTA_MODEL_ECONOMY=claude-haiku-4-5-20251001

# --- Midtrans (FR-23) ---
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
# MIDTRANS_IS_PRODUCTION=false
